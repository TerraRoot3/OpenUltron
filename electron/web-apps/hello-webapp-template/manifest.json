{
  "id": "com.openultron.hello",
  "name": "Hello Web App",
  "version": "1.0.0",
  "host": {
    "openUltron": ">=1.0.0",
    "protocol": 1
  },
  "entry": {
    "html": "index.html",
    "service": {
      "command": "node server.js",
      "cwd": ".",
      "portEnv": "PORT",
      "startupTimeoutMs": 20000
    }
  },
  "runtime": {
    "browser": true,
    "node": true
  }
}
